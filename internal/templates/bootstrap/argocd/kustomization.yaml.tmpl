apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: argocd

resources:
  - namespace.yaml
  - https://raw.githubusercontent.com/argoproj/argo-cd/v{{ .Controller.Version }}/manifests/install.yaml
  - appproject-default.yaml

patches:
  - path: argocd-cm-patch.yaml
  - path: argocd-rbac-cm-patch.yaml
